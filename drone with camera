    <!-- ===================== DOWNWARD CAMERA ===================== -->
    <!-- New link that carries a downward-facing RGB camera -->
<link name="downward_cam_link">
  <pose>0 0 0 0 0 0</pose>

  <sensor name="downward_camera" type="camera">
    <!-- Camera is mounted on downward_cam_link -->
    <parent>downward_cam_link</parent>

    <!-- Look straight down -->
    <pose>0 0 0 0 1.5708 0</pose>

    <update_rate>30</update_rate>
    <always_on>true</always_on>
    <visualize>true</visualize>

    <camera>
      <horizontal_fov>1.047</horizontal_fov>
      <image>
        <width>800</width>
        <height>800</height>
        <format>R8G8B8</format>
      </image>
      <clip>
        <near>0.1</near>
        <far>100</far>
      </clip>

      <!-- REQUIRED for camera_info -->
      <frame>downward_cam_frame</frame>
    </camera>

    <plugin name="downward_camera_controller" filename="libgazebo_ros_camera.so">
      <ros>
        <namespace>/</namespace>
        <remapping>image_raw:=/downward_cam/image_raw</remapping>
        <remapping>camera_info:=/downward_cam/camera_info</remapping>
      </ros>

      <camera_name>downward_cam</camera_name>
      <frame_name>downward_cam_frame</frame_name>
    </plugin>
  </sensor>
</link>

<!-- Attach camera to Iris -->
<joint name="downward_cam_joint" type="fixed">
  <parent>iris::base_link</parent>
  <child>downward_cam_link</child>
</joint>
